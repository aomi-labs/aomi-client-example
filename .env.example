# Aomi Backend
AOMI_BASE_URL=https://aomi.dev
AOMI_API_KEY=
AOMI_NAMESPACE=default
PUBLIC_KEY=

# EVM Wallet
PRIVATE_KEY=0x...         # EVM private key (hex with 0x prefix)
RPC_URL=https://eth.llamarpc.com
CHAIN_ID=1                # 1=mainnet, 42161=arbitrum, 8453=base, 10=optimism, 137=polygon

# Strategy
TOKEN=SOL
POSITION_SIZE_USD=1000
REBALANCE_THRESHOLD=0.05
MIN_FUNDING_RATE_APR=5
MAX_POSITION_USD=10000
MAX_DRAWDOWN=0.10

# Bot
LOOP_INTERVAL_MS=60000
DEBUG=false
