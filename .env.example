# Aomi Backend
AOMI_BASE_URL=https://aomi.dev
AOMI_API_KEY=
AOMI_APP=default
PUBLIC_KEY=

# EVM Wallet
PRIVATE_KEY=0x...         # EVM private key (hex with 0x prefix)
RPC_URL=https://eth.llamarpc.com
CHAIN_ID=1                # 1=mainnet, 42161=arbitrum, 8453=base, 10=optimism, 137=polygon

# Trading Pair
RISK_ASSET=wSOL
RISK_ASSET_ADDRESS=0xD31a59c85aE9D8edEFec411D448f90841571b89c
STABLE_ASSET=USDC
STABLE_ASSET_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# GeckoTerminal
GECKO_NETWORK=eth
OHLCV_POOL_ADDRESS=0x127452f3f9cdc0389b0bf59ce6131aa3bd763598  # wSOL/WETH pool on Uniswap V3

# Strategy
FAST_MA_PERIOD=6          # fast MA window (in tick samples)
SLOW_MA_PERIOD=12         # slow MA window (in hourly OHLCV candles)
MA_SPREAD_THRESHOLD=0.5   # % spread between MAs to trigger rotation
MAX_SLIPPAGE=1            # max acceptable slippage %
MAX_DRAWDOWN=15           # max drawdown % before emergency exit
TRADE_COOLDOWN_MS=300000  # 5 minutes between trades

# Portfolio (starting balances)
INITIAL_RISK_AMOUNT=39.34
INITIAL_STABLE_AMOUNT=99.60

# Bot
LOOP_INTERVAL_MS=120000   # 2 minutes between ticks
OHLCV_REFRESH_MS=600000   # 10 minutes between OHLCV refreshes
DEBUG=false
